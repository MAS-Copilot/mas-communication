{
  "metadata": [
    {
      "src": [
        {
          "src": "../",
          "files": [
            "src/**/*.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/*.Tests.csproj",
            "**/test/**"
          ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml" ,
      "properties": {
        "DefineConstants": "DOCFX"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "**/xrefmap.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "MAS.Communication",
      "_appTitle": "MAS.Communication API Reference",
      "_appFaviconPath": "images/favicon.ico",
      "_appLogoPath": "images/logo.svg",
      "_appFooter": "<span>Made with <a href=\"https://dotnet.github.io/docfx\" rel=\"noreferrer\">docfx</a>,  | Copyright (c) MAS(厦门威光) Corporation. All rights reserved.</span>",
      "_enableSearch": true,
      "pdf": false,
      "_gitContribute": {
        "repo": "https://github.com/MAS-Copilot/mas-communication",
        "branch": "main"
      }
    }
  }
}