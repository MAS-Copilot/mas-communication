ehthumbs.db
ehthumbs_vista.db

# docfx
docs/api/
docs/_site/
docs/mas.communication-docs/

# 忽略 Node.js 依赖
node_modules/

# 忽略 npm 缓存目录
.npm/

# 忽略操作系统生成的临时文件
*.tmp
*.temp
*.swp

# 忽略 IDE 特定文件
.idea/
*.sublime-project
*.sublime-workspace

# 忽略构建输出
