# VS 索引和缓存
*.ncb
*.sdf
*.cache
*.ilk
*.log

# Visual Studio 2015/2017 缓存/项目文件
.vs/
.vsconfig

# Windows image文件
Thumbs.db

# ReSharper 文件
_ReSharper*/

# 其他 JetBrains 工具
.idea/

# Resharper 和 Rider 缓存
[rR]e[Ss]harper*/
*.DotSettings.user

# TeamCity 项目
_TeamCity*

# 工具生成的文件夹
Generated_Code/

# 模板引擎相关
